# ============================================================
# Collaborative Issue Tracker — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values below.
# NEVER commit .env.local to version control.
# ============================================================

# ── Supabase Project Settings ──────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your project's unique URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Public anon key — safe to expose in the browser
# RLS is your security layer, not this key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# ── Optional / Future ──────────────────────────────────────
# Service role key — NEVER expose to the browser.
# Only needed for admin scripts or server-side bypasses (not used in this project).
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Site URL — used by Supabase Auth for redirects after email confirmation
NEXT_PUBLIC_SITE_URL=http://localhost:3000
